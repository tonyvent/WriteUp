<Window x:Class="WriteUp.AnnotationEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Annotate screenshot" Height="720" Width="1080"
        MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- Tool buttons: mutually exclusive radio buttons that look like toggles -->
        <Style x:Key="ToolButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Tools"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="root" Background="White" CornerRadius="8" Padding="12,7"
                                BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#FFF3E5E5"/>
                                <Setter TargetName="root" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="BorderBrush" Value="#FFBDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Color swatches -->
        <Style x:Key="Swatch" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Colors"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Ellipse x:Name="ring" Stroke="Transparent" StrokeThickness="2"
                                     Width="24" Height="24"/>
                            <Ellipse Fill="{TemplateBinding Background}" Width="16" Height="16"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ring" Property="Stroke" Value="{StaticResource InkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <RadioButton x:Name="ToolSelect" Style="{StaticResource ToolButton}" Content="⇱ Select" IsChecked="True"/>
                    <RadioButton x:Name="ToolArrow" Style="{StaticResource ToolButton}" Content="↗ Arrow"/>
                    <RadioButton x:Name="ToolBox" Style="{StaticResource ToolButton}" Content="▢ Box"/>
                    <RadioButton x:Name="ToolCallout" Style="{StaticResource ToolButton}" Content="💬 Callout"/>
                    <Rectangle Width="1" Fill="{StaticResource LineBrush}" Margin="4,2,10,2"/>
                    <RadioButton x:Name="ToolBlur" Style="{StaticResource ToolButton}" Content="▨ Blur"/>
                    <RadioButton x:Name="ToolRedact" Style="{StaticResource ToolButton}" Content="■ Redact"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="SwMaroon" Style="{StaticResource Swatch}" Background="#8A0101" IsChecked="True" ToolTip="Maroon"/>
                    <RadioButton x:Name="SwRed"    Style="{StaticResource Swatch}" Background="#E5484D" ToolTip="Red"/>
                    <RadioButton x:Name="SwBlue"   Style="{StaticResource Swatch}" Background="#0B68CB" ToolTip="Blue"/>
                    <RadioButton x:Name="SwGreen"  Style="{StaticResource Swatch}" Background="#18794E" ToolTip="Green"/>
                    <RadioButton x:Name="SwBlack"  Style="{StaticResource Swatch}" Background="#1A1A1A" ToolTip="Black"/>
                    <Rectangle Width="1" Fill="{StaticResource LineBrush}" Margin="6,2,12,2"/>
                    <Button x:Name="UndoBtn" Content="↩ Undo" Style="{StaticResource GhostButton}" Padding="12,7"
                            Margin="0,0,6,0" Click="Undo_Click"/>
                    <Button x:Name="DeleteBtn" Content="🗑 Delete" Style="{StaticResource GhostButton}" Padding="12,7"
                            Margin="0,0,6,0" IsEnabled="False" Click="DeleteSelected_Click"/>
                    <Button Content="Reset image…" Style="{StaticResource GhostButton}" Padding="12,7"
                            Click="Reset_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Callout text entry (visible only when a callout is selected) -->
        <Border x:Name="CalloutBar" Grid.Row="1" Background="#FFFBF3F3" CornerRadius="10"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="10,8"
                Margin="0,0,0,10" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CALLOUT TEXT" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Center" Margin="2,0,10,0"/>
                <TextBox Grid.Column="1" x:Name="CalloutTextBox" FontSize="13"
                         TextChanged="CalloutTextBox_TextChanged"/>
            </Grid>
        </Border>

        <!-- Image + drawing surface -->
        <Border Grid.Row="2" Background="#FF2A2A2E" CornerRadius="10" Padding="10">
            <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                <Grid x:Name="Surface" Cursor="Cross">
                    <Image x:Name="BaseImage" Stretch="Fill"/>
                    <Canvas x:Name="Ink" Background="Transparent"
                            MouseLeftButtonDown="Ink_MouseDown"
                            MouseMove="Ink_MouseMove"
                            MouseLeftButtonUp="Ink_MouseUp"/>
                </Grid>
            </Viewbox>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="2,12,2,0">
            <TextBlock x:Name="HintText" VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Text="Drag to draw. With the Select tool, drag a mark to move it, or drag its round grips to change an arrow's length/angle or a callout's head and label."/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox x:Name="ZoomInsetToggle" Content="Zoom inset" VerticalAlignment="Center"
                          Margin="0,0,16,0" Foreground="{StaticResource InkBrush}"
                          Visibility="Collapsed"
                          Checked="ZoomInset_Changed" Unchecked="ZoomInset_Changed"
                          ToolTip="Show and annotate the version with the magnified zoom window. Applies to the step when you Save."/>
                <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="Save" Style="{StaticResource BaseButton}" MinWidth="110"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
