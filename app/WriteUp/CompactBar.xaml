<Window x:Class="WriteUp.CompactBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WriteUp — recording"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual">
    <Border x:Name="Root" CornerRadius="10" Background="#FF1E1E20" Padding="12,7" Margin="16"
            MouseLeftButtonDown="Root_MouseLeftButtonDown" Cursor="SizeAll">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.45" Color="#FF000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- drag handle -->
            <TextBlock Text="⠿" Foreground="#FF6B6B6B" FontSize="15" VerticalAlignment="Center"
                       Margin="0,0,10,0" ToolTip="Drag to move"/>
            <Ellipse Width="11" Height="11" Fill="{StaticResource StopBrush}" Margin="0,0,8,0"
                     VerticalAlignment="Center"/>
            <TextBlock Text="REC" Foreground="White" FontWeight="Bold" FontSize="12"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding Elapsed}" Foreground="#FFDDDDDD" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="  ·  " Foreground="#FF888888" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center" Foreground="#FFDDDDDD" FontSize="12">
                <Run Text="{Binding StepCount, Mode=OneWay}"/><Run Text=" steps"/>
            </TextBlock>

            <Button Content="＋ Note" Style="{StaticResource BaseButton}" Background="#FF3A3A3D"
                    Padding="10,6" FontSize="12" Margin="14,0,0,0" Click="Note_Click"/>
            <Button Content="■ Stop" Style="{StaticResource BaseButton}" Background="{StaticResource StopBrush}"
                    Padding="12,6" FontSize="12" Margin="8,0,0,0" Click="Stop_Click"/>
        </StackPanel>
    </Border>
</Window>
