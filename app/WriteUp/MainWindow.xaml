<Window x:Class="WriteUp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WriteUp" Height="780" Width="1180"
        MinHeight="600" MinWidth="900"
        Topmost="{Binding AlwaysOnTop}"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="478" MinWidth="430"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*" MinWidth="380"/>
        </Grid.ColumnDefinitions>

        <!-- ============================ LEFT: capture ======================= -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="WriteUp" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"/>
                    <TextBlock Text="Record what you do, get a write-up." FontSize="13"
                               Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
                <CheckBox Content="Always on top" IsChecked="{Binding AlwaysOnTop, Mode=TwoWay}"
                          HorizontalAlignment="Right" VerticalAlignment="Top"
                          Foreground="{StaticResource MutedBrush}"/>
            </Grid>

            <!-- Document details -->
            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                <Expander Header="Document details" IsExpanded="True" Foreground="{StaticResource InkBrush}">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="TITLE" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Meta.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="SUBTITLE" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Meta.Subtitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="AUTHOR" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Meta.Author, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="COMPANY" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Meta.Company, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Grid Grid.Row="4" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DEPARTMENT" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Meta.Department, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="REVISION" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Meta.Revision, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="4" Grid.Column="2">
                            <TextBlock Text="LOGO" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" IsReadOnly="True"
                                         Text="{Binding Meta.LogoPath, Mode=OneWay}"/>
                                <Button Grid.Column="2" Content="Browse…" Style="{StaticResource GhostButton}"
                                        Padding="12,6" Click="BrowseLogo_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Expander>
            </Border>

            <!-- Control bar -->
            <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="RecordBtn" Style="{StaticResource RecordButton}"
                            Content="{Binding RecordButtonText}" Click="RecordBtn_Click"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="11" Height="11" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource MutedBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource StopBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                                   Foreground="{StaticResource InkBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="  ·  " VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding Elapsed}" VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="  ·  " VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}">
                            <Run Text="{Binding StepCount, Mode=OneWay}"/><Run Text=" steps"/>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="3" Content="＋ Add note" Style="{StaticResource GhostButton}"
                            Click="AddNote_Click" IsEnabled="{Binding IsRecording}"/>
                </Grid>
            </Border>

            <!-- Steps -->
            <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="6">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="10" Margin="2,4"
                                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="148" Height="84" CornerRadius="6"
                                                    ClipToBounds="True" Background="#FFF0F0F2"
                                                    Visibility="{Binding HasScreenshot, Converter={StaticResource BoolToVis}}">
                                                <Image Source="{Binding ScreenshotPath}" Stretch="UniformToFill"/>
                                            </Border>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Border Background="#FFFFEDE6" CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{Binding KindLabel}" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding AppLabel}" FontSize="11" Margin="8,0,0,0"
                                                               VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                                <TextBox Text="{Binding Caption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"
                                                         Background="Transparent" Padding="0" FontSize="14"/>
                                            </StackPanel>

                                            <Button Grid.Column="3" Content="✕" Style="{StaticResource GhostButton}"
                                                    Padding="10,6" VerticalAlignment="Top"
                                                    Click="DeleteStep_Click" ToolTip="Remove this step"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="340">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSteps}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="No steps yet" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource InkBrush}"/>
                        <TextBlock TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="Press Start, then work as you normally would. Every click is captured with a screenshot, and what you type becomes a step. Edit any description here before exporting."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Left footer: hotkey + output -->
            <StackPanel Grid.Row="4" Margin="2,12,0,0">
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12"
                           Text="Global hotkey: Ctrl+Alt+R to start/stop"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" Text="Output: "/>
                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12"
                               Text="{Binding OutputDir}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    <Button Content="Change…" Style="{StaticResource GhostButton}" Padding="8,2"
                            Margin="8,0,0,0" FontSize="11" Click="ChangeOutput_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                      Background="Transparent" ResizeBehavior="PreviousAndNext"/>

        <!-- ============================ RIGHT: preview ====================== -->
        <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="12"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Preview header -->
                <Grid Grid.Row="0" Margin="2,0,2,10">
                    <StackPanel>
                        <TextBlock Text="Report preview" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"/>
                        <TextBlock Text="What your exported write-up will look like." FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <CheckBox Content="Auto" IsChecked="{Binding AutoPreview, Mode=TwoWay}"
                                  VerticalAlignment="Center" Margin="0,0,12,0"
                                  Foreground="{StaticResource MutedBrush}" Click="AutoPreview_Click"/>
                        <Button Content="⟳ Refresh" Style="{StaticResource GhostButton}"
                                Padding="12,6" Click="Refresh_Click"/>
                    </StackPanel>
                </Grid>

                <!-- The preview itself -->
                <Border Grid.Row="1" Background="#FFF3F3F5" CornerRadius="8" Padding="2">
                    <FlowDocumentScrollViewer x:Name="PreviewViewer"
                                              IsToolBarVisible="True"
                                              VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Export bar -->
                <Grid Grid.Row="2" Margin="2,12,2,0">
                    <Button Content="Open folder" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left" Click="OpenFolder_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Markdown" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                                Click="ExportMarkdown_Click" IsEnabled="{Binding HasSteps}"/>
                        <Button Content="HTML" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                                Click="ExportHtml_Click" IsEnabled="{Binding HasSteps}"/>
                        <Button Content="Word (.rtf)" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                                Click="ExportWord_Click" IsEnabled="{Binding HasSteps}"/>
                        <Button Content="Export PDF" Style="{StaticResource BaseButton}"
                                Click="ExportPdf_Click" IsEnabled="{Binding HasSteps}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
