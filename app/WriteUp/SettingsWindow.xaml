<Window x:Class="WriteUp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="470" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        UseLayoutRounding="True">

    <StackPanel Margin="18">
        <TextBlock Text="Settings" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource InkBrush}" Margin="0,0,0,12"/>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="GUIDED TOUR" Style="{StaticResource FieldLabel}"/>
                <CheckBox x:Name="TourCheck" Content="Show the guided tour when the app starts"
                          Margin="0,6,0,10" Foreground="{StaticResource InkBrush}"/>
                <Button Content="Show tour now" Style="{StaticResource GhostButton}"
                        Padding="12,7" HorizontalAlignment="Left" Click="ShowTourNow_Click"/>
            </StackPanel>
        </Border>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="SESSIONS" Style="{StaticResource FieldLabel}"/>
                <CheckBox x:Name="CleanupCheck" Margin="0,6,0,4"
                          Foreground="{StaticResource InkBrush}"
                          Content="Delete session folders when the app closes"/>
                <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"
                           Text="Off: sessions (steps, screenshots, annotations) are kept and can be reopened later with 📂 Open… — they accumulate on disk until you delete them. On: capture folders are wiped on exit and past sessions cannot be reopened."/>
            </StackPanel>
        </Border>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="SCREENSHOTS" Style="{StaticResource FieldLabel}"/>
                <TextBlock Text="Maximum width (px). Larger captures are downscaled to this."
                           FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,6"/>
                <TextBox x:Name="MaxWidthBox" Width="120" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <Grid>
            <Button Content="Cancel" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource BaseButton}" MinWidth="100"
                    HorizontalAlignment="Right" Click="Save_Click"/>
        </Grid>
    </StackPanel>
</Window>
